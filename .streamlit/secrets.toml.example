# Copy this file to `.streamlit/secrets.toml` for local development,
# or paste these two lines into the Streamlit Cloud app's Secrets box
# (Manage app → Settings → Secrets).
#
# Without these, the app falls back to a local JSON file that is wiped on
# every Streamlit Cloud redeploy. With them, listings persist in Supabase.

SUPABASE_URL = "https://YOUR-PROJECT-ref.supabase.co"
SUPABASE_KEY = "YOUR-service_role-key"
